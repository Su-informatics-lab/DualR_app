# Copy this file to env.stage and fill in values.
# NEVER commit env.stage to git.

MODEL_DIR=models
CACHE_DIR=/tmp/dualr_cache

# MSU CatChat — backend-only fallback for novel drugs not in the lookup tables.
# Leave blank to disable CatChat (backend will fall back to disease prevalence).
CATCHAT_BASE_URL=https://catchat-api.msu.montana.edu/v1
CATCHAT_MODEL=gpt-oss:120b
CATCHAT_API_KEY=
